# Copy this file to .env on the server before running docker compose.
# Replace example.com and all secrets with real production values.

DATABASE_URL=sqlite:////app/backend/data/app.db
CORS_ORIGINS=https://example.com

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
JWT_SECRET=change-this-long-random-secret
JWT_EXPIRE_MINUTES=1440
ANALYTICS_SALT=change-this-long-random-salt

# Used only at frontend image build time.
FRONTEND_API_URL=https://example.com

# Local-only container ports. Host nginx can proxy to these.
BACKEND_PORT=18000
FRONTEND_PORT=15173
